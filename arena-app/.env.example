# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# Database (use arena_app role after running R-03 migration in production)
DATABASE_URL="postgresql://arena_app:password@localhost:5432/arena_db"

# Redis / BullMQ
REDIS_URL="redis://localhost:6379"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."

# Oracle signing — minimum 32 chars, keep secret
ORACLE_HMAC_SECRET="change-me-to-a-long-random-secret-string"

# Blockchain — Base L2 (use Base Sepolia for dev)
BASE_RPC_URL="https://sepolia.base.org"
PLATFORM_WALLET_ADDRESS="0x..."
PLATFORM_WALLET_KEY_SECRET_ARN="arn:aws:secretsmanager:us-east-1:123456789:secret:arena/platform-wallet-key"
CONTEST_RESULTS_CONTRACT="0x..."

# Clerk
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."

# AWS
AWS_REGION="us-east-1"
ECS_CLUSTER_ARN="arn:aws:ecs:us-east-1:123456789:cluster/arena-runners"
ECS_TASK_DEFINITION_ARN="arn:aws:ecs:us-east-1:123456789:task-definition/arena-runner:1"
S3_ORACLE_EXPORT_BUCKET="arena-oracle-results"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_ANNUAL="price_..."
